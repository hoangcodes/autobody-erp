# Base URL of the AutoSuite API (backend). The client appends /api/v1 to this.
VITE_API_URL=http://localhost:4000

# Use the in-memory mock data layer instead of the real backend.
# Default is TRUE (mocks on) while the backend isn't running, so every screen
# renders and is interactive. Set to "false" to hit the real API at VITE_API_URL.
VITE_USE_MOCKS=true

# Supabase project used for auth (optional in dev — DEV_AUTH_BYPASS on the
# backend means the app works fine with these left blank; supabase.ts guards
# against missing config).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
